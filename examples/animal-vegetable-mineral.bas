10 MODE 0
20 CLS
30 PRINT "ANIMAL VEGETABLE MINERAL"
40 PRINT "THINK OF SOMETHING"
50 PRINT "PRESS ENTER WHEN READY"
60 INPUT A$
70 GOSUB 9000
80 GOSUB 5000
90 GOSUB 5500
100 GOSUB 6000
105 IF READY<>1 THEN GOTO 120
110 GOSUB 7000
120 GOSUB 8000
130 GOSUB 9100
140 GOTO 40

5000 REM ==== INIT RUNTIME STATE ONLY ====
5010 IF INITED=1 THEN RETURN
5020 DIM OS(20),A(20),USED(20),ALIVE(20)
5030 LET INITED=1
5040 RETURN

5500 REM ==== RESET ROUND STATE ====
5510 FOR I=1 TO NO
5520 LET OS(I)=0
5530 LET ALIVE(I)=1
5540 NEXT I
5550 FOR J=1 TO NQ
5560 LET A(J)=0
5570 LET USED(J)=0
5580 NEXT J
5590 LET CORRECT=-2
5600 LET GOBJECT$=""
5610 LET NEW$=""
5620 LET QNEW$=""
5630 LET ASKED=0
5640 LET READY=0
5650 RETURN

6000 REM ==== QUESTION LOOP ====
6005 LET STEPQ=1
6010 GOSUB 6500
6020 IF Q<>0 THEN GOTO 6030
6025 LET READY=1
6026 RETURN
6030 PRINT QQ$(Q)
6040 INPUT R$
6050 IF R$="YES" THEN GOTO 6070
6055 IF R$="NO" THEN GOTO 6075
6060 PRINT "ANSWER YES OR NO"
6065 GOTO 6040
6070 LET A(Q)=1
6071 GOTO 6080
6075 LET A(Q)=-1
6080 LET USED(Q)=1
6081 PRINT "DEBUG Q=";Q;" A(Q)=";A(Q);" USED(Q)=";USED(Q)
6082 PRINT "DEBUG W11=";W(1,1);" W21=";W(2,1);" W31=";W(3,1)
6090 LET ASKED=ASKED+1
6100 GOSUB 8700
6110 GOSUB 6700
6115 FOR I=1 TO NO
6116 PRINT "DEBUG OS(";I;")=";OS(I)
6117 NEXT I
6120 GOSUB 8800
6125 PRINT "DEBUG AFTER 8800 READY=";READY
6130 IF READY=1 THEN RETURN
6135 LET STEPQ=STEPQ+1
6140 IF STEPQ<=NQ THEN GOTO 6010
6150 LET READY=1
6160 RETURN

6500 REM ==== CHOOSE NEXT QUESTION ====
6510 LET Q=0
6520 LET BESTS=-1
6530 LET T1=0:LET T2=0:LET S1=-32767:LET S2=-32767
6540 FOR I=1 TO NO
6550 IF ALIVE(I)=0 THEN GOTO 6565
6560 IF OS(I)>S1 THEN LET S2=S1:LET T2=T1:LET S1=OS(I):LET T1=I ELSE IF OS(I)>S2 THEN LET S2=OS(I):LET T2=I
6565 NEXT I
6570 IF T1=0 OR T2=0 THEN GOTO 6660
6580 FOR J=1 TO NQ
6590 IF USED(J)=1 THEN GOTO 6640
6600 LET D=W(T1,J)-W(T2,J)
6610 LET S=ABS(D)
6620 IF S>BESTS THEN LET BESTS=S:LET Q=J
6640 NEXT J
6650 IF Q<>0 THEN RETURN
6660 FOR J=1 TO NQ
6670 IF USED(J)=0 THEN LET Q=J:RETURN
6680 NEXT J
6690 LET Q=0
6695 RETURN

6700 REM ==== UPDATE OBJECT SCORES ====
6710 FOR I=1 TO NO
6720 IF ALIVE(I)=0 THEN LET OS(I)=-32767:GOTO 6770
6730 LET S=0
6740 FOR J=1 TO NQ
6750 LET S=S+W(I,J)*A(J)
6760 NEXT J
6765 LET OS(I)=S
6770 NEXT I
6780 RETURN

7000 REM ==== MAKE GUESS ====
7010 IF READY<>1 THEN RETURN
7020 LET BEST=-32767
7030 LET GI=0
7040 FOR I=1 TO NO
7050 IF ALIVE(I)=0 THEN GOTO 7080
7060 IF GI=0 THEN LET BEST=OS(I):LET GI=I:GOTO 7080
7070 IF OS(I)>BEST THEN LET BEST=OS(I):LET GI=I
7080 NEXT I
7090 IF GI=0 THEN LET GI=1
7100 LET GOBJECT$=ON$(GI)
7110 PRINT "IS IT A ";GOBJECT$;"?"
7120 INPUT G$
7130 IF G$="YES" THEN PRINT "I GOT IT!":LET CORRECT=-1:RETURN
7140 IF G$="NO" THEN LET CORRECT=0:RETURN
7150 PRINT "ANSWER YES OR NO"
7160 GOTO 7110

8000 REM ==== TEACH IF WRONG ====
8010 IF CORRECT<>0 THEN RETURN
8020 PRINT "WHAT WAS IT?"
8030 INPUT NEW$
8040 LET EXIST=0
8050 FOR I=1 TO NO
8060 IF ON$(I)=NEW$ THEN LET EXIST=I
8070 NEXT I
8080 IF EXIST=0 THEN GOSUB 9300 ELSE LET OI=EXIST
8090 IF OI=0 THEN RETURN
8100 FOR J=1 TO NQ
8110 IF USED(J)=0 THEN GOTO 8140
8120 LET W(OI,J)=A(J)
8140 NEXT J
8150 PRINT "GIVE ME A QUESTION TO DISTINGUISH ";NEW$;" FROM ";GOBJECT$
8160 INPUT QNEW$
8162 LET QI=0
8164 FOR J=1 TO NQ
8166 IF QQ$(J)=QNEW$ THEN LET QI=J
8168 NEXT J
8170 IF QI<>0 THEN GOTO 8200
8172 IF NQ=20 THEN PRINT "NO MORE QUESTIONS":RETURN
8174 LET NQ=NQ+1
8176 LET QI=NQ
8178 QQ$(QI)=QNEW$
8200 PRINT "FOR ";NEW$;" WHAT IS THE ANSWER (YES/NO)?"
8210 INPUT AN$
8220 IF AN$="YES" THEN LET WNEW=1 ELSE LET WNEW=-1
8230 LET W(OI,QI)=WNEW
8240 LET GI=0
8250 FOR I=1 TO NO
8260 IF ON$(I)=GOBJECT$ THEN LET GI=I
8270 NEXT I
8280 IF GI>0 THEN LET W(GI,QI)=-WNEW
8290 GOSUB 8400
8300 RETURN

8400 REM ==== PROPAGATE NEW QUESTION ====
8410 FOR I=1 TO NO
8420 IF I=OI THEN GOTO 8490
8430 IF I=GI THEN GOTO 8490
8440 PRINT "FOR ";ON$(I);" WOULD THE ANSWER TO ";QNEW$;" BE YES OR NO?"
8450 INPUT PX$
8460 IF PX$="YES" THEN LET W(I,QI)=1:GOTO 8490
8470 IF PX$="NO" THEN LET W(I,QI)=-1:GOTO 8490
8480 LET W(I,QI)=0
8490 NEXT I
8500 RETURN

8700 REM ==== EXCLUDE IMPOSSIBLE OBJECTS ====
8710 FOR I=1 TO NO
8720 IF ALIVE(I)=0 THEN GOTO 8770
8730 FOR J=1 TO NQ
8740 IF USED(J)=0 THEN GOTO 8760
8750 IF W(I,J)<>0 AND W(I,J)<>A(J) THEN LET ALIVE(I)=0:GOTO 8770
8760 NEXT J
8770 NEXT I
8780 RETURN

8800 REM ==== DECIDE IF READY TO GUESS ====
8810 LET READY=0
8820 LET BEST=-32767
8821 LET NEXTBEST=-32767
8822 LET GI2=0
8830 FOR I=1 TO NO
8840 IF ALIVE(I)=0 THEN GOTO 8880
8850 IF OS(I)>BEST THEN GOTO 8860
8855 IF OS(I)>NEXTBEST THEN LET NEXTBEST=OS(I)
8856 GOTO 8880
8860 LET NEXTBEST=BEST
8870 LET BEST=OS(I)
8875 LET GI2=I
8880 NEXT I
8890 PRINT "DEBUG READY BEST=";BEST;" NEXTBEST=";NEXTBEST;" ASKED=";ASKED;" GI2=";GI2
8895 IF GI2<>0 THEN GOTO 8900
8896 RETURN
8900 IF ASKED=NQ THEN GOTO 8960
8910 IF ASKED<2 THEN RETURN
8920 IF BEST>NEXTBEST THEN GOTO 8930
8925 RETURN
8930 LET MAXS=ASKED
8940 IF BEST*10>=MAXS*7 THEN GOTO 8960
8950 IF BEST-NEXTBEST>=2 THEN GOTO 8960
8955 RETURN
8960 LET READY=1
8970 RETURN

9000 REM ==== LOAD KNOWLEDGE HOOK ====
9010 RETURN

9100 REM ==== OFFER SAVE ====
9110 IF CORRECT=-2 THEN RETURN
9120 PRINT "DO YOU WANT TO SAVE THE LEARNING?"
9130 INPUT S$
9140 PRINT "LEARNING STORED"
9150 PRINT "NEW GAME"
9160 RETURN

9300 REM ==== ADD NEW OBJECT ====
9310 IF NO=20 THEN PRINT "MEMORY FULL":LET OI=0:RETURN
9320 LET NO=NO+1
9330 LET OI=NO
9340 ON$(OI)=NEW$
9350 RETURN